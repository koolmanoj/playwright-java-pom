pipeline {
    agent any

     parameters {
            choice(name: 'BROWSER',
                   choices: ['chromium', 'firefox', 'webkit'])

             booleanParam(
                        name: 'HEADLESS',
                        defaultValue: true,
                        description: 'Run in headless mode'
                    )
        }

/*     tools {
            jdk 'JDK21'
            maven 'Maven3'
    } */

/*     environment {

            MAVEN_OPTS = '-Xmx1024m'

            BROWSER = 'chromium'

            ENV = 'qa'
    } */
    stages {
        stage('Checkout') {
        steps {
            echo 'Checking out source code...'

            git branch: 'main',
            url: 'https://github.com/koolmanoj/playwright-java-pom.git'
        }
    }

     stage('Start Selenium Grid') {

                steps {

                    echo 'Starting Selenium Grid...'

                    //bat 'docker compose -f src/main/java/com/qa/demoqa/docker/docker-compose.yaml up -d'
                }
            }


    stage('Build') {
        steps {
            echo 'Building framework...'

            bat 'mvn clean package -DskipTests'
        }
    }
        stage('Deploy to QA') {
        steps{
            echo 'Deploy to QA'
            }
        }

        stage('Regression Test Execution') {

        steps {
        echo 'Executing Regression tests'

        bat """ mvn clean test -DsuiteXmlFile=testng-regression.xml -Dbrowser=%BROWSER% -Dheadless=%HEADLESS% """
        }
            post {
                always {
                   junit 'target/surefire-reports/*.xml'

                    //echo 'Stopping Selenium Grid...'

                    //bat 'docker compose -f src/main/java/com/qa/demoqa/docker/docker-compose.yaml'
                }
            }
        }
    }
}